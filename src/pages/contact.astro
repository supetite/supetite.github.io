---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Contact | Cam Thanh Ha LE" sideBarActiveItemID="contact">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Contact & Connect</div>
  </div>

  <div class="mb-10 text-justify">
    Whether you want to discuss the future of <b>UWB technology</b>, explore a collaboration in <b>Edge AI</b>, or just say hello, I'd love to hear from you. I am currently based in <b>Toulouse, France</b>, but I'm always open to global professional connections.
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Email Card -->
    <a href="mailto:lecamthanhha@gmail.com" class="card bg-base-200 transition-all hover:scale-[1.02] shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <div class="text-3xl text-primary">📧</div>
        <div>
          <h2 class="text-lg font-bold">Email</h2>
          <p class="text-sm opacity-70">lecamthanhha@gmail.com</p>
        </div>
      </div>
    </a>

    <!-- LinkedIn Card -->
    <a href="https://www.linkedin.com/in/cam-thanh-ha-le/" target="_blank" class="card bg-base-200 transition-all hover:scale-[1.02] shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <div class="text-3xl text-primary">🔗</div>
        <div>
          <h2 class="text-lg font-bold">LinkedIn</h2>
          <p class="text-sm opacity-70">in/cam-thanh-ha-le</p>
        </div>
      </div>
    </a>

    <!-- Phone Card -->
    <div class="card bg-base-200 shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <div class="text-3xl text-primary">📱</div>
        <div>
          <h2 class="text-lg font-bold">Phone</h2>
          <p class="text-sm opacity-70">+33 7 83 69 12 89</p>
        </div>
      </div>
    </div>

    <!-- GitHub Card -->
    <a href="https://github.com/supetite" target="_blank" class="card bg-base-200 transition-all hover:scale-[1.02] shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <div class="text-3xl text-primary">💻</div>
        <div>
          <h2 class="text-lg font-bold">GitHub</h2>
          <p class="text-sm opacity-70">supetite</p>
        </div>
      </div>
    </a>
  </div>

  <div class="mt-10 p-6 bg-primary/10 rounded-xl border border-primary/20">
    <h3 class="font-bold mb-2">Current Status:</h3>
    <p>📍 Based in <b>Toulouse, France</b>. </p>
  </div>
</BaseLayout>