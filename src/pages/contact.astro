---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Contact | Cam Thanh Ha LE" sideBarActiveItemID="contact">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Contact & Connect</div>
  </div>

  <div class="mb-10 text-justify">
    Whether you want to discuss, explore a collaboration, or just say hello, I'd love to hear from you. I am currently based in <b>Toulouse, France</b>, but I'm always open to global professional connections.
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Email Card -->
    <a href="mailto:lecamthanhha@gmail.com" class="card bg-base-200 transition-all hover:scale-[1.02] shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" style="fill: currentColor;transform: ;msFilter:;">
          <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
        <div>
          <h2 class="text-lg font-bold">Email</h2>
          <p class="text-sm opacity-70">lecamthanhha@gmail.com</p>
        </div>
      </div>
    </a>

    <!-- LinkedIn Card -->
    <a href="https://www.linkedin.com/in/cam-thanh-ha-le/" target="_blank" class="card bg-base-200 transition-all hover:scale-[1.02] shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" style="fill: currentColor;transform: ;msFilter:;">
          <circle cx="4.983" cy="5.009" r="2.188"/>
          <path d="M9.237 8.855v12.139h3.769v-6.003c0-1.584.298-3.118 2.262-3.118 1.937 0 1.961 1.811 1.961 3.218v5.904H21v-6.657c0-3.27-.704-5.783-4.526-5.783-1.835 0-3.065 1.007-3.568 1.96h-.051v-1.66H9.237zm-6.142 0H6.87v12.139H3.095z"/>
        </svg>
        <div>
          <h2 class="text-lg font-bold">LinkedIn</h2>
          <p class="text-sm opacity-70">in/cam-thanh-ha-le</p>
        </div>
      </div>
    </a>

    <!-- Phone Card -->
    <div class="card bg-base-200 shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" style="fill: currentColor;transform: ;msFilter:;">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <div>
          <h2 class="text-lg font-bold">Phone</h2>
          <p class="text-sm opacity-70">+33 7 83 69 12 89</p>
        </div>
      </div>
    </div>

    <!-- GitHub Card -->
    <a href="https://github.com/supetite" target="_blank" class="card bg-base-200 transition-all hover:scale-[1.02] shadow-md border border-base-300">
      <div class="card-body flex-row items-center gap-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" style="fill: currentColor;transform: ;msFilter:;">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12.026 2c-5.509 0-9.974 4.465-9.974 9.974 0 4.406 2.857 8.145 6.821 9.465.499.09.679-.217.679-.481 0-.237-.008-.865-.011-1.696-2.775.602-3.361-1.338-3.361-1.338-.452-1.152-1.107-1.459-1.107-1.459-.905-.619.069-.605.069-.605 1.002.07 1.527 1.028 1.527 1.028.89 1.524 2.336 1.084 2.902.829.091-.645.351-1.085.635-1.334-2.214-.251-4.542-1.107-4.542-4.93 0-1.087.389-1.979 1.024-2.675-.101-.253-.446-1.268.099-2.64 0 0 .837-.269 2.742 1.021a9.582 9.582 0 0 1 2.496-.336 9.554 9.554 0 0 1 2.496.336c1.906-1.291 2.742-1.021 2.742-1.021.545 1.372.203 2.387.099 2.64.64.696 1.024 1.587 1.024 2.675 0 3.833-2.33 4.675-4.552 4.922.355.308.675.916.675 1.846 0 1.334-.012 2.41-.012 2.737 0 .267.178.577.687.479C19.146 20.115 22 16.379 22 11.974 22 6.465 17.535 2 12.026 2z"/>
        </svg>
        <div>
          <h2 class="text-lg font-bold">GitHub</h2>
          <p class="text-sm opacity-70">supetite</p>
        </div>
      </div>
    </a>
  </div>

  <div class="mt-10 p-6 bg-primary/10 rounded-xl border border-primary/20">
    <h3 class="font-bold mb-2">Current Status:</h3>
    <p>📍 Based in <b>Toulouse, France</b>. </p>
  </div>
</BaseLayout>