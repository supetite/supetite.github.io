---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Research & Engineering Projects</div>
  </div>

  <HorizontalCard
    title="Constraining Latent Space for Medical Diagnosis"
    img="/post_img.webp"
    desc="Developed a Deep Learning approach for skin disease classification, presented during a seminar at Torus AI. The project focused on 'Explainable AI' (XAI) by constraining the neural network's latent space to align with specific clinical characteristics, ensuring that model predictions are interpretable by medical professionals."
    url="#"
    badge="Research / XAI"
  />
  
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Deep Image Prior for Inverse Problems"
    img="/post_img.webp"
    desc="Applied Convolutional Neural Networks (CNNs) to solve inverse problems in image processing without the need for large training datasets. Implemented Deep Image Prior techniques for high-quality image restoration, including inpainting, denoising, and super-resolution."
    url="#"
    badge="Computer Vision / Image Processing"
  />


  <div class="divider my-0"></div>

  <HorizontalCard
    title="Sentiment Analysis Optimization (IA Pau)"
    img="/post_img.webp"
    desc="Winner of the Data Challenge 2022 IA Pau. Developed an NLP pipeline optimized for the Boavizta project, balancing sentiment analysis accuracy with environmental impact. Focused on reducing the carbon footprint of AI model training and inference."
    url="#"
    badge="Award Winner"
  />
</BaseLayout>
